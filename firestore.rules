rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isCoachOf(studentId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(studentId)).data.coachId == request.auth.uid;
    }

    match /globalExercises/{exerciseId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Production rule for coach feedback updates — takes effect once the catch-all below is removed.
    match /workoutLogs/{logId} {
      allow update: if isCoachOf(resource.data.studentId)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['coachFeedback', 'coachFeedbackPending']);
    }

    match /{document=**} {
      // TODO: tighten these rules before production deployment.
      // Open access is used to support local emulator testing.
      allow read, write: if true;
    }
  }
}
