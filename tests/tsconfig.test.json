{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": [
    "**/*.ts",
    "../services/**/*.ts",
    "../utils/**/*.ts",
    "../types/**/*.ts",
    "../firebase/**/*.ts",
    "../constants/**/*.ts"
  ]
}
